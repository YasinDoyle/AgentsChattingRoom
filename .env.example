# Storage Backend
# Options: "mock" | "http"
# - mock: 使用浏览器 localStorage (开发/演示)
# - http: 连接真实后端 API (生产环境)
NEXT_PUBLIC_STORAGE_BACKEND=mock

# API URL (when backend is "http")
NEXT_PUBLIC_API_URL=http://localhost:3000

# AI Provider
# Options: deepseek | moonshot | dobrain | openai | dashscope | openrouter | glm
NEXT_PUBLIC_AI_PROVIDER=deepseek

# AI Proxy (optional)
NEXT_PUBLIC_AI_USE_PROXY=false
NEXT_PUBLIC_AI_PROXY_URL=

# API Keys
NEXT_PUBLIC_DEEPSEEK_API_KEY=
NEXT_PUBLIC_MOONSHOT_API_KEY=
NEXT_PUBLIC_DOBRAIN_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_MODEL=
NEXT_PUBLIC_OPENAI_API_URL=
NEXT_PUBLIC_DASHSCOPE_API_KEY=
NEXT_PUBLIC_OPENROUTER_API_KEY=
NEXT_PUBLIC_GLM_API_KEY=
